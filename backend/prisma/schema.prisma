generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Gender {
  Male
  Female
  Other
}

enum WeightCategory {
  BELOW_50KG @map("Below 50kg")
  FIFTY_KG   @map("50kg")
  ABOVE_50KG @map("Above 50kg")
}

enum BloodGroup {
  A_POSITIVE  @map("A+")
  A_NEGATIVE  @map("A-")
  B_POSITIVE  @map("B+")
  B_NEGATIVE  @map("B-")
  AB_POSITIVE @map("AB+")
  AB_NEGATIVE @map("AB-")
  O_POSITIVE  @map("O+")
  O_NEGATIVE  @map("O-")
}

enum AdminType {
  super
  regular
}

enum OtpPurpose {
  registration
  forgot_password
}

model Donor {
  id                 String           @id @default(uuid()) @db.Uuid
  fullName           String           @map("full_name") @db.VarChar(100)
  phone              String           @unique @db.VarChar(20)
  email              String           @unique @db.VarChar(100)
  passwordHash       String           @map("password_hash") @db.VarChar(255)
  gender             Gender
  city               String           @db.VarChar(100)
  age                Int
  weight             WeightCategory
  bloodGroup         BloodGroup       @map("blood_group")
  hasDisease         Boolean          @map("has_disease")
  diseaseDescription String?          @map("disease_description") @db.Text
  previouslyDonated  Boolean          @map("previously_donated")
  lastDonatedDate    DateTime?        @map("last_donated_date") @db.Date
  eligible           Boolean          @default(true)
  unresponsiveCount  Int              @default(0) @map("unresponsive_count")
  disqualified       Boolean          @default(false)
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  donations          Donation[]

  @@index([bloodGroup, city])
  @@index([eligible, disqualified])
  @@index([lastDonatedDate])
  @@map("donors")
}

model Admin {
  id           String     @id @default(uuid()) @db.Uuid
  name         String     @db.VarChar(100)
  phone        String     @unique @db.VarChar(20)
  email        String     @unique @db.VarChar(100)
  passwordHash String     @map("password_hash") @db.VarChar(255)
  adminType    AdminType  @map("admin_type")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  auditLogs    AuditLog[]

  @@map("admins")
}

model Donation {
  id           String   @id @default(uuid()) @db.Uuid
  donorId      String   @map("donor_id") @db.Uuid
  donationDate DateTime @map("donation_date") @db.Date
  createdAt    DateTime @default(now()) @map("created_at")

  donor        Donor    @relation(fields: [donorId], references: [id])

  @@map("donations")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  adminId    String?  @map("admin_id") @db.Uuid
  adminName  String   @map("admin_name") @db.VarChar(100)
  action     String   @db.VarChar(50)
  entityType String   @map("entity_type") @db.VarChar(50)
  entityId   String   @map("entity_id") @db.Uuid
  details    Json?
  createdAt  DateTime @default(now()) @map("created_at")

  admin      Admin?   @relation(fields: [adminId], references: [id], onDelete: SetNull)

  @@index([adminId, createdAt])
  @@map("audit_logs")
}

model Otp {
  id          String     @id @default(uuid()) @db.Uuid
  email       String     @db.VarChar(100)
  otpCode     String     @map("otp_code") @db.VarChar(10)
  purpose     OtpPurpose
  pendingData Json?      @map("pending_data")
  expiresAt   DateTime   @map("expires_at")
  used        Boolean    @default(false)
  createdAt   DateTime   @default(now()) @map("created_at")

  @@map("otps")
}
